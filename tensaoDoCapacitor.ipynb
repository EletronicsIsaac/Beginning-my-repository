   "source": [
    "import math\n",
    "\n",
    "def tensao_capacitor(V, R, C, t):\n",
    "    return V * (1 - math.exp(-t/(R*C)))\n",
    "\n",
    "resultado = tensao_capacitor(5, 1000, 1e-6, 0.01)\n",
    "\n",
    "print(\"Tensão no capacitor:\", resultado)"
   ]
  }
